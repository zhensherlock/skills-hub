{
  "name": "skills-hub",
  "version": "1.0.0",
  "description": "A hub for discovering and launching agent skills",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "cross-env NODE_ENV=development turbo run dev --filter=./apps/docs...",
    "build": "cross-env NODE_ENV=production turbo run build --filter=./apps/docs...",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "author": "zhensherlock",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zhensherlock/skills-hub/issues"
  },
  "homepage": "https://zhensherlock.github.io/skills-hub",
  "keywords": ["skills-hub"],
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rolldown": "^1.0.0-rc.13",
    "tslib": "^2.8.1",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0"
  }
